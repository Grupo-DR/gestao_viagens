rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      // Temporário: Assume true para teste local sem Auth real
      return true;
    }

    function hasRole(role) {
      // Simulado: Otimizado para o modo Provisório (IdentityContext)
      return true;
    }

    function isValidTravelRequest(data) {
      // Validação Polimórfica (Interno vs Externo)
      let employeeValid = data.employee.passengerType == 'external'
        ? data.employee.fullName is string && data.employee.cpfOrPassport is string
        : data.employee.chapa is string;

      return data.keys().hasAll(['status', 'employee', 'travel', 'audit']) &&
             data.status is string &&
             employeeValid &&
             data.travel.reason is string &&
             (!data.travel.keys().hasAll(['isUrgent']) || data.travel.isUrgent is bool) &&
             data.audit.createdAt is string;
    }

    // Rules
    match /users/{uid} {
      allow read, write: if request.auth != null;
    }

    match /travelRequests/{requestId} {
      // Leitura permitida para autenticados. Escrita requer dados válidos e autenticação.
      allow read: if request.auth != null;
      allow write: if request.auth != null && isValidTravelRequest(request.resource.data);
    }
  }
}
