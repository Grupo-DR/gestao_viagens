# ============================================================
# CONFIGURAÇÃO DE AMBIENTE — DR TravelHub
# Copie este arquivo para .env e preencha com as chaves reais.
# NUNCA suba o arquivo .env para o GitHub!
# ============================================================

# Firebase Configuration
VITE_FIREBASE_API_KEY=sua_chave_aqui
VITE_FIREBASE_AUTH_DOMAIN=seu_projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=id_do_seu_projeto
VITE_FIREBASE_STORAGE_BUCKET=seu_projeto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=seu_sender_id
VITE_FIREBASE_APP_ID=seu_app_id
VITE_FIREBASE_FIRESTORE_DB_ID=(default)

# TOTVS RM Integration
VITE_RM_SQL_BASE_URL=https://drconstrutora116480.rm.cloudtotvs.com.br:8051/api/framework/v1/consultaSQLServer/RealizaConsulta
VITE_RM_AUTHORIZATION=Basic [seu_token_base64]
